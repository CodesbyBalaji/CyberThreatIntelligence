# ============================================================================
# ADVANCED THREAT FUSION ENGINE - CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your API keys
# Get free API keys from the URLs provided below

# ============================================================================
# THREAT INTELLIGENCE API KEYS
# ============================================================================

# AlienVault OTX (Free) - https://otx.alienvault.com/api
# Sign up for a free account and get your API key from the API Integration page
OTX_API_KEY=your_otx_api_key_here

# VirusTotal (Free tier: 4 requests/min) - https://www.virustotal.com/gui/my-apikey
# Create a free account and get your API key from your profile
VT_API_KEY=your_virustotal_api_key_here

# AbuseIPDB (Free tier: 1000 requests/day) - https://www.abuseipdb.com/account/api
# Sign up and get your API key from the API section
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# Shodan (Optional) - https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key_here

# GreyNoise (Optional) - https://www.greynoise.io/
GREYNOISE_API_KEY=your_greynoise_api_key_here

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================

# Choose your LLM provider: 'ollama' (local), 'openai', or 'google'
LLM_PROVIDER=ollama

# OpenAI API Key (if using OpenAI) - https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google AI API Key (if using Gemini) - https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Ollama Configuration (if using local LLM)
OLLAMA_URL=http://localhost:11434
LLM_MODEL=gemma2:2b

# ============================================================================
# ADVANCED FEATURES
# ============================================================================

# Enable/Disable Advanced Features
ENABLE_PREDICTION=true
ENABLE_PLAYBOOKS=true
ENABLE_YARA=true
ENABLE_GEOLOCATION=true
AUTO_ENRICHMENT=true

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Feed update interval in seconds (default: 3600 = 1 hour)
FEED_UPDATE_INTERVAL=3600

# Maximum items to fetch from each feed
MAX_FEED_ITEMS=100

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# Enable caching
ENABLE_CACHING=true

# ============================================================================
# SECURITY
# ============================================================================

# Enable audit logging
ENABLE_AUDIT_LOG=true

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# DATABASE
# ============================================================================

# Database path (relative to project root)
DB_PATH=threat_fusion.db

# Vector index path
VECTOR_INDEX_PATH=threat_vectors.index

# Knowledge graph path
KNOWLEDGE_GRAPH_PATH=knowledge_graph.json
